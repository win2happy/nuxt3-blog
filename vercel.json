{
    "framework": null,
    "buildCommand": "pnpm build",
    "installCommand": "pnpm install",
    "github": {
        "silent": true,
        "autoJobCancelation": true
    },
    "routes": [
        {
            "src": "/robots.txt",
            "headers": {
                "content-type": "text/plain"
            },
            "dest": "/robots.txt",
            "continue": true
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate, max-age=0"
                }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                {
                    "key": "content-type",
                    "value": "text/plain"
                }
            ]
        }
    ]
}